# PostgreSQL connection string for SeaBorg (required)
DATABASE_URL=postgresql://user:password@localhost:5432/seaborg

# Groq API key for LLM responses (required for later phases)
GROQ_API_KEY=gsk_...

# Optional Hugging Face token (recommended for sentence-transformers downloads)
HUGGINGFACE_TOKEN=hf_...

# App environment: development or production
ENVIRONMENT=development

# Path to the saved FAISS index file
FAISS_INDEX_PATH=indexes/argo.faiss

# Path to the Parquet file used by the RAG pipeline
PARQUET_PATH=data/processed/argo.parquet

# Distance threshold for FAISS search (used to filter out weak matches)
FAISS_DISTANCE_THRESHOLD=1.5

# LLM model name (configure here; never hardcode elsewhere)
LLM_MODEL=llama-3.1-8b-instant

# Backend API URL used by the frontend
API_URL=http://localhost:8000

# Frontend URL used by the backend for CORS
FRONTEND_URL=http://localhost:5173
